{
  "name": "opapp-desktop",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "lint": "echo \"TODO: configure desktop lint\"",
    "doctor": "echo \"TODO: configure desktop doctor\"",
    "test": "npm run verify:windows",
    "commit:check": "npm run verify:windows:dev",
    "commit:check:release": "npm run verify:windows",
    "commit:check:infra": "npm run test:windows:release-diagnostics && npm run test:windows:release-smoke:ota && npm run test:frontend-ref:resolve && npm run test:windows:nightly-assets && npm run test:ota:publish && npm run test:registry:ops && npm run test:ota:updater && npm run smoke:ota",
    "dev:windows": "node ./tooling/scripts/dev-windows.mjs",
    "verify:windows:dev": "node ./tooling/scripts/verify-windows-dev.mjs",
    "smoke:windows:dev:reuse": "node ./tooling/scripts/verify-windows-dev.mjs --skip-prepare",
    "verify:windows": "node ./tooling/scripts/verify-windows.mjs",
    "verify:windows:portable": "node ./tooling/scripts/verify-windows.mjs --launch=portable",
    "smoke:windows": "node ./tooling/scripts/windows-release-smoke.mjs --scenario=tab-session",
    "smoke:windows:reuse": "node ./tooling/scripts/windows-release-smoke.mjs --skip-prepare",
    "smoke:windows:portable": "node ./tooling/scripts/windows-release-smoke.mjs --launch=portable --scenario=tab-session",
    "smoke:windows:portable:reuse": "node ./tooling/scripts/windows-release-smoke.mjs --launch=portable --skip-prepare",
    "verify:windows:public:ci": "node ./tooling/scripts/windows-public-verify.mjs",
    "verify:windows:raw-release": "node ./tooling/scripts/windows-release-raw-build.mjs",
    "capture:windows:window": "node ./tooling/scripts/windows-capture-window.mjs",
    "report:windows:release-probe": "node ./tooling/scripts/windows-release-probe-report.mjs",
    "report:windows:release-probe:json": "node ./tooling/scripts/windows-release-probe-report.mjs --json",
    "report:windows:release-probe:fail": "node ./tooling/scripts/windows-release-probe-report.mjs --fail-on-blocking",
    "report:windows:timing": "node ./tooling/scripts/windows-smoke-timing-report.mjs",
    "test:windows-capture:options": "node --test ./tooling/scripts/windows-capture-window-options.test.mjs",
    "test:windows:release-diagnostics": "node ./tooling/scripts/windows-release-diagnostics.test.mjs",
    "test:windows:release-smoke:ota": "node ./tooling/scripts/windows-release-smoke-ota.test.mjs",
    "test:frontend-ref:resolve": "node --test ./tooling/scripts/resolve-public-frontend-ref.test.mjs",
    "test:windows:nightly-assets": "node --test ./tooling/scripts/windows-nightly-release-assets.test.mjs ./tooling/scripts/windows-signing.test.mjs ./tooling/scripts/windows-official-release-manifest.test.mjs ./tooling/scripts/windows-official-release-assets.test.mjs",
    "ota:check": "node ./tooling/scripts/ota-updater.mjs --mode=check",
    "ota:download": "node ./tooling/scripts/ota-updater.mjs --mode=download",
    "ota:apply": "node ./tooling/scripts/ota-updater.mjs --mode=apply",
    "ota:update": "node ./tooling/scripts/ota-updater.mjs --mode=update",
    "ota:rollback": "node ./tooling/scripts/ota-updater.mjs --mode=rollback",
    "ota:fixture:native-failure": "node ./tooling/scripts/ota-native-failure-fixture.mjs",
    "registry:prune": "node ./tooling/scripts/registry-pruner.mjs",
    "ota:prune": "node ./tooling/scripts/registry-pruner.mjs --dir=.ota-cache",
    "watchdog:guard": "node ./tooling/scripts/crash-watchdog.mjs --mode=guard",
    "watchdog:heartbeat": "node ./tooling/scripts/crash-watchdog.mjs --mode=heartbeat",
    "smoke:ota": "node ./tooling/scripts/ota-smoke.mjs",
    "registry:rollout:get": "node ./tooling/scripts/registry-ops.mjs rollout --get",
    "registry:rollout:set": "node ./tooling/scripts/registry-ops.mjs rollout --set",
    "registry:channel:get": "node ./tooling/scripts/registry-ops.mjs channel --get",
    "registry:channel:set": "node ./tooling/scripts/registry-ops.mjs channel --set",
    "registry:channel:unset": "node ./tooling/scripts/registry-ops.mjs channel --unset",
    "ota:publish:cloudflare": "node ./tooling/scripts/ota-cloudflare-publish.mjs",
    "ota:build:publish:cloudflare": "node ./tooling/scripts/ota-cloudflare-publish.mjs --build",
    "test:ota:publish": "node ./tooling/scripts/ota-cloudflare-publish.test-runner.mjs",
    "test:registry:ops": "node ./tooling/scripts/registry-ops.test.mjs",
    "test:ota:updater": "node ./tooling/scripts/ota-updater.test.mjs",
    "test:ota:native-failure-fixture": "node ./tooling/scripts/ota-native-failure-fixture.test.mjs"
  },
  "license": "MPL-2.0",
  "description": "Desktop host repo and release tooling for OPApp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opappdev/opapp-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/opappdev/opapp-desktop/issues"
  },
  "homepage": "https://github.com/opappdev/opapp-desktop#readme"
}
